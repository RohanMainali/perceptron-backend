PORT=4000
ADMIN_SECRET_KEY=replace-me-with-a-strong-passphrase
AUTH_TOKEN_SECRET=replace-me-with-a-different-secret
TOKEN_EXPIRY=30m
ALLOWED_ORIGINS=http://localhost:3000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/perceptron

# Resend (https://resend.com) — used for sending approval emails
RESEND_API_KEY=re_replace_with_your_resend_api_key
FROM_EMAIL=Auta <noreply@yourdomain.com>

# CVAT annotation tool integration
# Internal base URL reachable by THIS backend server (e.g. http://cvat-server:8080 or https://your-cvat-domain.com)
CVAT_API_URL=http://localhost:8080
# Public-facing URL shown to new users in the welcome email (can be same as CVAT_API_URL)
CVAT_PUBLIC_URL=https://your-cvat-domain.com
# Must match CVAT_INTERNAL_API_KEY set in docker-compose.yml / CVAT environment
CVAT_INTERNAL_API_KEY=replace-with-a-strong-random-secret
